generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----

enum UserRole {
  patient
  admin
}

// ---- Models ----

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  dob         String?
  bloodType   String?
  gender      String?
  role        UserRole  @default(patient)
  isOnboarded Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedBy   String?
  lastLoginAt DateTime?
}
