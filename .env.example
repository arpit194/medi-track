# Set to "true" to use mock API implementations instead of real HTTP calls.
# Use this during development before a backend is available.
VITE_DUMMY_APIS=true

# Base URL for the real API. Only used when VITE_DUMMY_APIS is not "true".
VITE_API_URL=http://localhost:3001/api

# Deployment target for Nitro (TanStack Start's server engine).
# Set to "vercel" when deploying to Vercel, otherwise omit.
NITRO_PRESET=vercel
